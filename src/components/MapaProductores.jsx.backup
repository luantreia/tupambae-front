import React, { useEffect, memo, useCallback } from 'react';
import { MapContainer, TileLayer, Marker, Popup, useMap, useMapEvents } from 'react-leaflet';
import 'leaflet/dist/leaflet.css';
import L from 'leaflet';
import { useNavigate } from 'react-router-dom';
import { getCategoryIcon, getCategoryLabel } from '../constants/categories';
import MobileMapOptimization from './MobileMapOptimization';

// Fix para los iconos de Leaflet en React
import icon from 'leaflet/dist/images/marker-icon.png';
import iconShadow from 'leaflet/dist/images/marker-shadow.png';

let DefaultIcon = L.icon({
    iconUrl: icon,
    shadowUrl: iconShadow,
    iconSize: [25, 41],
    iconAnchor: [12, 41]
});

L.Marker.prototype.options.icon = DefaultIcon;

// Componente para controlar el movimiento del mapa
const MapController = memo(({ center, zoom, forceFly }) => {
  const map = useMap();
  useEffect(() => {
    if (center && forceFly) {
      map.flyTo(center, zoom || 14, {
        duration: 1.5
      });
    }
  }, [center, zoom, map, forceFly]);
  return null;
};

// Componente para capturar clicks y seleccionar ubicación manual
const ClickHandler = memo(({ onMapClick }) => {
  const handleClick = useCallback((e) => {
    onMapClick([e.latlng.lat, e.latlng.lng]);
  }, [onMapClick]);

  useMapEvents({
    click: handleClick
  });
  return null;
};

// Función para agrupar productores por cercanía geográfica (memoizada)
const groupProducersByLocation = (producers) => {
  const groups = {};
  producers.forEach(p => {
    if (p.ubicacion && p.ubicacion.lat && p.ubicacion.lng) {
      // Agrupamos por coordenadas redondeadas a 3 decimales (~110m de precisión)
      const key = `${p.ubicacion.lat.toFixed(3)},${p.ubicacion.lng.toFixed(3)}`;
      if (!groups[key]) {
        groups[key] = {
          lat: p.ubicacion.lat,
          lng: p.ubicacion.lng,
          producers: []
        };
      }
      groups[key].producers.push(p);
    }
  });
  return Object.values(groups);
};

const MapaProductores = memo(({ producers, center = [-34.6037, -58.3816], zoom = 12, onMapClick, userLocation }) => {
  const navigate = useNavigate();
  const groupedProducers = React.useMemo(() => groupProducersByLocation(producers), [producers]);
  const hasCustomCenter = !!userLocation;
  const isMobile = window.innerWidth < 768;

  return (
    <div className="h-[450px] w-full rounded-3xl overflow-hidden shadow-inner border border-gray-100 mb-8 z-0 relative">
      <style>
        {`
          .leaflet-popup-content-wrapper {
            border-radius: 1.5rem;
            padding: 0.5rem;
          }
          .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
          }
          .custom-scrollbar::-webkit-scrollbar-track {
            background: #f1f1f1;
          }
          .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #888;
            border-radius: 2px;
          }
        `}
      </style>
      <MapContainer 
        center={hasCustomCenter ? userLocation : center} 
        zoom={zoom} 
        style={{ height: '100%', width: '100%' }}
        zoomControl={true}
      >
        <TileLayer
          attribution='&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
          url="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
        />
        
        <MapController center={hasCustomCenter ? userLocation : center} zoom={zoom} forceFly={hasCustomCenter} />
        
        {onMapClick && <ClickHandler onMapClick={onMapClick} />}
        
        {groupedProducers.map((group, index) => (
          <Marker 
            key={`${group.lat}-${group.lng}-${index}`}
            position={[group.lat, group.lng]}
            icon={L.divIcon({
              html: `<div class="flex items-center justify-center w-8 h-8 bg-green-600 rounded-full shadow-lg border-2 border-white">
                <span class="text-white text-xs font-bold">${group.producers.length}</span>
              </div>`,
              className: 'custom-marker',
              iconSize: [32, 32],
              iconAnchor: [16, 16]
            })}
          >
            <Popup maxWidth={300} className="custom-popup">
              <div className="p-4 max-h-60 overflow-y-auto custom-scrollbar">
                <h3 className="font-bold text-lg mb-3 text-gray-800">
                  {group.producers.length > 1 ? `${group.producers.length} Productores` : group.producers[0].nombre}
                </h3>
                <div className="space-y-3">
                  {group.producers.map((producer, idx) => (
                    <div key={producer._id} className="border-b border-gray-100 pb-3 last:border-0">
                      <div className="flex items-start gap-3">
                        <div className="w-12 h-12 bg-gray-200 rounded-lg flex items-center justify-center">
                          <span className="text-xl">{getCategoryIcon(producer.categoria)}</span>
                        </div>
                        <div className="flex-1">
                          <h4 className="font-semibold text-gray-800">{producer.nombre}</h4>
                          <p className="text-sm text-gray-600 mb-2">{getCategoryLabel(producer.categoria)}</p>
                          <div className="flex items-center gap-2 text-xs text-gray-500">
                            <span>📍 {producer.zona}</span>
                            {producer.rating && (
                              <span>⭐ {producer.rating.toFixed(1)}</span>
                            )}
                          </div>
                          <button
                            onClick={() => navigate(`/productor/${producer._id}`)}
                            className="mt-2 w-full bg-green-600 hover:bg-green-700 text-white text-sm font-medium py-2 px-4 rounded-lg transition-colors"
                          >
                            Ver Productos
                          </button>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </Popup>
          </Marker>
        ))}
      </MapContainer>
      
      {/* Optimizaciones para móvil */}
      <MobileMapOptimization map={undefined} isMobile={isMobile} />
      
      <div className="bg-amber-50 p-2 text-center text-[10px] text-amber-700 font-bold uppercase tracking-widest">
        ⚠️ Ubicaciones aproximadas para proteger la privacidad de los productores
      </div>
    </div>
  );
});

export default MapaProductores;
